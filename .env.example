# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google Sheets
# サービスアカウントのJSONキーファイルパス
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json
# スプレッドシートのID（URLの /d/ と /edit の間の文字列）
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Alerts RSS フィードURL（複数はカンマ区切り）
GOOGLE_ALERTS_RSS_URLS=https://www.google.com/alerts/feeds/xxxxx

# PR TIMES 検索キーワード（カンマ区切り）
PRTIMES_KEYWORDS=健康経営,ウェルビーイング,従業員健康,メンタルヘルス,産業保健

# Claude モデル設定
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096
